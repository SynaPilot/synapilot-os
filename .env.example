# =============================================================================
# SynaPilot OS — Environment Variables
# =============================================================================
# Copy this file to .env (frontend) and supabase/.env (Edge Functions).
# Never commit .env files with real secrets.
# =============================================================================

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>

# ── Supabase Edge Functions ───────────────────────────────────────────────────
# Set via: supabase secrets set KEY=value
# Or via the Supabase dashboard → Settings → Edge Functions → Secrets

# Supabase project
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>   # NEVER expose to frontend

# Stripe
STRIPE_SECRET_KEY=sk_live_<your-key>                # sk_test_... for dev
STRIPE_PRICE_ID=price_<your-price-id>               # 150 EUR/agent/month recurring price
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>   # from Stripe Dashboard → Webhooks

# Application
APP_URL=https://app.synapilot.fr                    # no trailing slash
# APP_URL=http://localhost:5173                      # for local dev

# ── Stripe Webhook — subscribed events ───────────────────────────────────────
# Register these events in Stripe Dashboard → Developers → Webhooks:
#   checkout.session.completed
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_failed
#   invoice.payment_succeeded
#
# Webhook endpoint URL:
#   https://<project-ref>.supabase.co/functions/v1/stripe-webhook
